{
  "expo": {
    "name": "1ShopStore",
    "slug": "1shopstore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parasale.1shopstore",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.parasale.shopstore",
      "versionCode": 1
    },
    "scheme": "com.parasale.shopstore",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidSupportExclusion",
      "expo-dev-client",
      "expo-apple-authentication",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "1ShopStore uses the microphone to let you search by voice.",
          "speechRecognitionPermission": "1ShopStore uses speech recognition to convert your voice into a search query."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0c2d5e",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "1ShopStore uses your location to show nearby delivery options."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "84c9e70d-2992-4443-aa3d-121f784aa07d"
      }
    },
    "owner": "prasadbadhan"
  }
}
